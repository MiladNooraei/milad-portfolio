---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";
import Hero from "@/components/widgets/Hero.astro";

const base = "/milad-portfolio/";

const metadata = {
  title: `${siteConfig.name} — Portfolio`,
  description:
    "Portfolio of Milad Nooraei, a Master of Data Science student at Monash University with experience in data analysis, visualization, and applied analytics.",
  ignoreTitleTemplate: true,
};
---

<BaseLayout {metadata}>
  <Hero
    title={`Turning Data into <br class="hidden md:block" /> <span class="bg-linear-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">Insight</span>`}
    tagline="Monash University • Melbourne"
    description="I’m Milad Nooraei, a Master of Data Science student at Monash University with experience in data analysis, machine learning, and data visualization. I work with tools like Python, SQL, Power BI, and statistical methods to explore data, uncover patterns, and support better decision-making across healthcare, sports, and digital datasets."
    actions={[
      {
        text: "View Projects",
        href: `${base}services/`,
        variant: "primary",
        icon: "lucide:folder-open",
      },
      {
        text: "Contact Me",
        href: `${base}contact/`,
        variant: "secondary",
        icon: "lucide:mail",
        ariaLabel: "Go to contact page",
      },
    ]}
  />
</BaseLayout>
