---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";
import me from "@/assets/images/me.png";

const base = "/milad-portfolio/";

const metadata = {
  title: `${siteConfig.name} — Portfolio`,
  description:
    "Portfolio of Milad Nooraei, a Master of Data Science student at Monash University with experience in data analysis, visualization, and applied analytics.",
  ignoreTitleTemplate: true,
};
---

<BaseLayout {metadata}>
  <section class="relative overflow-hidden">
    <!-- BACKGROUND -->
    <div class="pointer-events-none absolute inset-0 z-0 overflow-hidden">
      <svg
        class="absolute bottom-[-10px] left-0 h-[220px] w-full opacity-75"
        viewBox="0 0 1440 220"
        preserveAspectRatio="none"
        aria-hidden="true"
      >
        <g transform="translate(40 0)">
          <rect class="bar b1" x="0" y="120" width="28" height="100" rx="8"
          ></rect>
          <rect class="bar b2" x="52" y="70" width="28" height="150" rx="8"
          ></rect>
          <rect class="bar b3" x="104" y="96" width="28" height="124" rx="8"
          ></rect>
          <rect class="bar b4" x="156" y="42" width="28" height="178" rx="8"
          ></rect>
          <rect class="bar b5" x="208" y="88" width="28" height="132" rx="8"
          ></rect>
          <rect class="bar b6" x="260" y="58" width="28" height="162" rx="8"
          ></rect>
          <rect class="bar b7" x="312" y="112" width="28" height="108" rx="8"
          ></rect>
          <rect class="bar b8" x="364" y="84" width="28" height="136" rx="8"
          ></rect>
          <rect class="bar b9" x="416" y="64" width="28" height="156" rx="8"
          ></rect>
          <rect class="bar b10" x="468" y="100" width="28" height="120" rx="8"
          ></rect>
          <rect class="bar b11" x="520" y="78" width="28" height="142" rx="8"
          ></rect>
          <rect class="bar b12" x="572" y="48" width="28" height="172" rx="8"
          ></rect>
          <rect class="bar b13" x="624" y="82" width="28" height="138" rx="8"
          ></rect>
          <rect class="bar b14" x="676" y="60" width="28" height="160" rx="8"
          ></rect>
          <rect class="bar b15" x="728" y="108" width="28" height="112" rx="8"
          ></rect>
          <rect class="bar b16" x="780" y="72" width="28" height="148" rx="8"
          ></rect>
          <rect class="bar b17" x="832" y="92" width="28" height="128" rx="8"
          ></rect>
          <rect class="bar b18" x="884" y="54" width="28" height="166" rx="8"
          ></rect>
          <rect class="bar b19" x="936" y="84" width="28" height="136" rx="8"
          ></rect>
          <rect class="bar b20" x="988" y="66" width="28" height="154" rx="8"
          ></rect>
          <rect class="bar b21" x="1040" y="102" width="28" height="118" rx="8"
          ></rect>
          <rect class="bar b22" x="1092" y="74" width="28" height="146" rx="8"
          ></rect>
          <rect class="bar b23" x="1144" y="90" width="28" height="130" rx="8"
          ></rect>
          <rect class="bar b24" x="1196" y="58" width="28" height="162" rx="8"
          ></rect>
        </g>
      </svg>
    </div>

    <!-- CONTENT -->
    <section class="relative z-10 mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
      <div class="grid items-center gap-12 md:grid-cols-2">
        <div class="text-center md:text-left">
          <div
            class="mb-4 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/10 px-4 py-1 text-sm font-semibold text-primary"
          >
            <span class="relative flex h-2 w-2" aria-hidden="true">
              <span
                class="absolute inline-flex h-full w-full rounded-full bg-primary/60 opacity-75 animate-ping motion-reduce:animate-none"
              ></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-primary"
              ></span>
            </span>
            Monash University • Melbourne
          </div>

          <h1
            class="mb-6 text-5xl font-extrabold tracking-tight text-foreground md:text-7xl"
          >
            Turning Data into
            <br class="hidden md:block" />
            <span
              class="bg-linear-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent"
            >
              Insight
            </span>
          </h1>

          <p
            class="mx-auto mb-10 max-w-2xl text-xl text-muted-foreground md:mx-0"
          >
            I’m Milad Nooraei, a Master of Data Science student at Monash
            University with experience in data analysis, machine learning, and
            data visualization. I work with tools like Python, SQL, Power BI,
            and statistical methods to explore data, uncover patterns, and
            support better decision-making across different domains.
          </p>

          <div
            class="flex flex-col items-center justify-center gap-4 sm:flex-row md:justify-start"
          >
            <a
              href={`${base}services/`}
              class="inline-flex items-center justify-center rounded-2xl bg-foreground px-6 py-3 text-base font-semibold text-background shadow-lg transition hover:opacity-90"
            >
              View Projects
            </a>

            <a
              href={`${base}contact/`}
              class="inline-flex items-center justify-center rounded-2xl border border-border bg-card px-6 py-3 text-base font-semibold text-foreground transition hover:bg-foreground/5"
            >
              Contact Me
            </a>
          </div>
        </div>

        <div class="flex justify-center md:justify-end">
          <div class="group relative">
            <div
              class="absolute -inset-2 rounded-[2rem] bg-[radial-gradient(circle_at_top_left,rgba(96,165,250,0.25),transparent_40%),radial-gradient(circle_at_bottom_right,rgba(168,85,247,0.25),transparent_40%)] blur-xl opacity-80 transition duration-300 group-hover:opacity-100"
            >
            </div>

            <img
              src={me.src}
              alt="Milad Nooraei"
              class="relative h-[360px] w-[300px] rounded-[2rem] border border-border object-cover shadow-2xl transition duration-300 group-hover:-translate-y-1 group-hover:shadow-[0_0_40px_rgba(96,165,250,0.18)] md:h-[420px] md:w-[340px]"
            />
          </div>
        </div>
      </div>
    </section>
  </section>

  <style>
    .bar {
      transform-origin: center bottom;
      animation: barMove 4.8s ease-in-out infinite;
    }

    .b1 {
      fill: rgba(96, 165, 250, 0.18);
      animation-delay: 0s;
    }
    .b2 {
      fill: rgba(168, 85, 247, 0.16);
      animation-delay: 0.15s;
    }
    .b3 {
      fill: rgba(236, 72, 153, 0.14);
      animation-delay: 0.3s;
    }
    .b4 {
      fill: rgba(96, 165, 250, 0.2);
      animation-delay: 0.45s;
    }
    .b5 {
      fill: rgba(168, 85, 247, 0.16);
      animation-delay: 0.6s;
    }
    .b6 {
      fill: rgba(236, 72, 153, 0.14);
      animation-delay: 0.75s;
    }
    .b7 {
      fill: rgba(96, 165, 250, 0.18);
      animation-delay: 0.9s;
    }
    .b8 {
      fill: rgba(168, 85, 247, 0.16);
      animation-delay: 1.05s;
    }
    .b9 {
      fill: rgba(236, 72, 153, 0.14);
      animation-delay: 1.2s;
    }
    .b10 {
      fill: rgba(96, 165, 250, 0.18);
      animation-delay: 1.35s;
    }
    .b11 {
      fill: rgba(168, 85, 247, 0.16);
      animation-delay: 1.5s;
    }
    .b12 {
      fill: rgba(236, 72, 153, 0.14);
      animation-delay: 1.65s;
    }
    .b13 {
      fill: rgba(96, 165, 250, 0.18);
      animation-delay: 1.8s;
    }
    .b14 {
      fill: rgba(168, 85, 247, 0.16);
      animation-delay: 1.95s;
    }
    .b15 {
      fill: rgba(236, 72, 153, 0.14);
      animation-delay: 2.1s;
    }
    .b16 {
      fill: rgba(96, 165, 250, 0.18);
      animation-delay: 2.25s;
    }
    .b17 {
      fill: rgba(168, 85, 247, 0.16);
      animation-delay: 2.4s;
    }
    .b18 {
      fill: rgba(236, 72, 153, 0.14);
      animation-delay: 2.55s;
    }
    .b19 {
      fill: rgba(96, 165, 250, 0.18);
      animation-delay: 2.7s;
    }
    .b20 {
      fill: rgba(168, 85, 247, 0.16);
      animation-delay: 2.85s;
    }
    .b21 {
      fill: rgba(236, 72, 153, 0.14);
      animation-delay: 3s;
    }
    .b22 {
      fill: rgba(96, 165, 250, 0.18);
      animation-delay: 3.15s;
    }
    .b23 {
      fill: rgba(168, 85, 247, 0.16);
      animation-delay: 3.3s;
    }
    .b24 {
      fill: rgba(236, 72, 153, 0.14);
      animation-delay: 3.45s;
    }

    @keyframes barMove {
      0%,
      100% {
        transform: scaleY(1);
      }
      50% {
        transform: scaleY(1.1);
      }
    }
  </style>
</BaseLayout>
