---
import BaseLayout from "@/layouts/BaseLayout.astro";

const metadata = {
  title: "CV",
  description: "View and download Milad Nooraei's CV.",
};

const base = import.meta.env.BASE_URL;
const cvPath = `${base}Milad_Nooraei_CV.pdf`;
---

<BaseLayout {metadata}>
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mb-8 text-center">
      <h1 class="text-4xl font-bold text-foreground">My CV</h1>
      <p class="mt-2 text-muted-foreground">
        You can view my CV below or download it for later.
      </p>
    </div>

    <div class="mb-8 flex justify-center gap-4">
      <a
        href={cvPath}
        target="_blank"
        class="rounded-xl bg-foreground px-6 py-3 text-sm font-semibold text-background transition hover:opacity-90"
      >
        Open in New Tab
      </a>

      <a
        href={cvPath}
        download
        class="rounded-xl border border-border px-6 py-3 text-sm font-semibold text-foreground transition hover:bg-foreground/5"
      >
        Download CV
      </a>
    </div>

    <div class="overflow-hidden rounded-2xl border border-border shadow-lg">
      <iframe src={cvPath} class="h-[800px] w-full"></iframe>
    </div>
  </section>
</BaseLayout>
