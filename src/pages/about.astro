  <script is:inline>
    document.addEventListener("astro:page-load", () => {
      const links = document.querySelectorAll(".about-nav-link");
      const sections = document.querySelectorAll("section[id]");

      const setActiveLink = (id) => {
        links.forEach((link) => {
          const isActive = link.getAttribute("data-section-link") === id;
          link.classList.toggle("bg-foreground/10", isActive);
          link.classList.toggle("text-foreground", isActive);
          link.classList.toggle("font-semibold", isActive);
          link.classList.toggle("text-primary", isActive);
          link.classList.toggle("shadow-sm", isActive);
        });
      };

      const observer = new IntersectionObserver(
        (entries) => {
          const visibleEntries = entries.filter(
            (entry) => entry.isIntersecting,
          );
          if (visibleEntries.length > 0) {
            const topMost = visibleEntries.sort(
              (a, b) => a.boundingClientRect.top - b.boundingClientRect.top,
            )[0];
            setActiveLink(topMost.target.id);
          }
        },
        {
          rootMargin: "-20% 0px -60% 0px",
          threshold: 0.1,
        },
      );

      sections.forEach((section) => observer.observe(section));

      const currentHash = window.location.hash.replace("#", "");
      if (currentHash) {
        setActiveLink(currentHash);
      } else {
        setActiveLink("intro");
      }
