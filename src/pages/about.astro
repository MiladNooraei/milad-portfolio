---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";

const metadata = {
  title: "About",
  description:
    "Learn more about Milad Nooraei, a Master of Data Science student at Monash University with experience in analytics, programming, and data visualization.",
};
---

<BaseLayout {metadata}>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <!-- Fixed left nav on large screens -->
    <aside class="fixed left-6 top-28 z-20 hidden w-56 xl:block">
      <div
        class="rounded-3xl border border-border bg-card/70 p-5 shadow-sm backdrop-blur"
      >
        <p
          class="mb-4 text-sm font-semibold uppercase tracking-wider text-primary"
        >
          On this page
        </p>

        <nav class="space-y-2" id="about-side-nav">
          <a
            href="#intro"
            data-section-link="intro"
            class="about-nav-link flex items-center gap-3 rounded-xl px-3 py-2 text-sm text-muted-foreground transition hover:bg-foreground/5 hover:text-foreground"
          >
            <Icon name="lucide:user-round" class="h-4 w-4" />
            <span>About Me</span>
          </a>

          <a
            href="#education"
            data-section-link="education"
            class="about-nav-link flex items-center gap-3 rounded-xl px-3 py-2 text-sm text-muted-foreground transition hover:bg-foreground/5 hover:text-foreground"
          >
            <Icon name="lucide:graduation-cap" class="h-4 w-4" />
            <span>Education</span>
          </a>

          <a
            href="#experience"
            data-section-link="experience"
            class="about-nav-link flex items-center gap-3 rounded-xl px-3 py-2 text-sm text-muted-foreground transition hover:bg-foreground/5 hover:text-foreground"
          >
            <Icon name="lucide:briefcase" class="h-4 w-4" />
            <span>Experience</span>
          </a>

          <a
            href="#activities"
            data-section-link="activities"
            class="about-nav-link flex items-center gap-3 rounded-xl px-3 py-2 text-sm text-muted-foreground transition hover:bg-foreground/5 hover:text-foreground"
          >
            <Icon name="lucide:users" class="h-4 w-4" />
            <span>Activities</span>
          </a>

          <a
            href="#skills"
            data-section-link="skills"
            class="about-nav-link flex items-center gap-3 rounded-xl px-3 py-2 text-sm text-muted-foreground transition hover:bg-foreground/5 hover:text-foreground"
          >
            <Icon name="lucide:hammer" class="h-4 w-4" />
            <span>Skills</span>
          </a>

          <a
            href="#beyond-data"
            data-section-link="beyond-data"
            class="about-nav-link flex items-center gap-3 rounded-xl px-3 py-2 text-sm text-muted-foreground transition hover:bg-foreground/5 hover:text-foreground"
          >
            <Icon name="lucide:music" class="h-4 w-4" />
            <span>Beyond Data</span>
          </a>
        </nav>
      </div>
    </aside>

    <!-- Main content -->
    <div class="xl:ml-72 space-y-8">
      <!-- Intro -->
      <section
        id="intro"
