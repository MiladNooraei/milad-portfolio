---
import { siteConfig } from "@/config/site";
---

<footer class="mt-20 border-t border-border bg-card">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center justify-between gap-8 md:flex-row">
      <!-- Left -->
      <div class="flex flex-col items-center gap-2 md:items-start">
        <span class="text-lg font-bold text-foreground">
          {siteConfig.name}
        </span>
        <p class="text-sm text-muted-foreground">
          {siteConfig.description}
        </p>
      </div>

      <!-- Right (Updated Links) -->
      <div class="flex items-center gap-6 text-sm">
        <!-- Email -->
        <a
          href="mailto:mnoo0018@student.monash.edu"
          class="text-muted-foreground transition duration-300 hover:text-blue-400 hover:font-semibold hover:drop-shadow-[0_0_8px_rgba(96,165,250,0.6)]"
        >
          Email
        </a>

        <!-- LinkedIn -->
        <a
          href="https://www.linkedin.com/in/milad-nooraei/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground transition duration-300 hover:text-blue-400 hover:font-semibold hover:drop-shadow-[0_0_8px_rgba(96,165,250,0.6)]"
        >
          LinkedIn
        </a>

        <!-- Instagram -->
        <a
          href="https://www.instagram.com/milad___nooraei"
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground transition duration-300 hover:text-blue-400 hover:font-semibold hover:drop-shadow-[0_0_8px_rgba(96,165,250,0.6)]"
        >
          Instagram
        </a>
      </div>
    </div>

    <!-- Bottom -->
    <div
      class="mt-8 border-t border-border pt-8 text-center text-xs text-muted-foreground"
    >
      &copy; {new Date().getFullYear()}
      {siteConfig.author}. All rights reserved.
    </div>
  </div>
</footer>
